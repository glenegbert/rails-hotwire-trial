<div class="like-button" id="like-button-<%= photo.id %>"
     data-controller="like"
     data-like-liked-value="<%= like.present? %>"
     data-like-fill-path-value="<%= image_path('star-fill.svg') %>"
     data-like-line-path-value="<%= image_path('star-line.svg') %>">
  <% if like %>
    <%= button_to photo_like_path(photo, like), method: :delete, class: "like-btn liked",
                  data: { action: "turbo:submit-start->like#optimistic" } do %>
      <%= image_tag "star-fill.svg", alt: "Unlike" %>
    <% end %>
  <% else %>
    <%= button_to photo_likes_path(photo), method: :post, class: "like-btn",
                  data: { action: "turbo:submit-start->like#optimistic" } do %>
      <%= image_tag "star-line.svg", alt: "Like" %>
    <% end %>
  <% end %>
  <span data-like-target="count"><%= photo.likes_count %></span>
</div>
